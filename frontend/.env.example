# Next.js — copy to `frontend/.env.local` for local `next dev` on the host.
# In Docker, `docker-compose.yml` sets NEXT_PUBLIC_API_URL and INTERNAL_API_URL (override via root `.env`).

# Browser and client components: reachable from the user’s machine (not the Docker service name).
# Base URL only — do NOT append /api (fetch paths already include /api/...).
NEXT_PUBLIC_API_URL=http://localhost:8000
# Testing on a real phone: use your PC’s LAN IP (e.g. http://192.168.1.42:8000) so the phone can reach Django.
# Production (Vercel/Railway): `next.config.mjs` adds `/media/**` for this host automatically from NEXT_PUBLIC_API_URL.

# Server Components / Route Handlers inside the frontend container: Compose service hostname.
# Same rule as NEXT_PUBLIC_API_URL: origin only, no trailing /api.
INTERNAL_API_URL=http://backend:8000

# Django REST Framework: /api/* is staff-only. Server-side fetchJson() sends this token so the
# public site still loads. Create a token for a staff user (see backend/.env.example). Never expose
# this in NEXT_PUBLIC_* (keep server-only).
# INTERNAL_API_AUTH_TOKEN=

# Optional: site URL for metadata, canonical links, OG tags.
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Hero video: upload MP4 in Django admin → Site settings (served via /api/site-settings/).
# Optional override (takes effect only if admin has no hero video):
# NEXT_PUBLIC_HERO_VIDEO_URL=https://example.com/your-drone-reel.mp4

# Contact page (public).
# NEXT_PUBLIC_CONTACT_PHONE=+90 212 555 00 00
# Optional full address string (shown on İletişim). Default is Esenler office if unset.
# NEXT_PUBLIC_CONTACT_ADDRESS=Nine Hatun, İnönü Cd. No:31, 34220 Esenler/İstanbul
# Maps “Haritada aç” defaults to the firm’s share link in code. Override if the place URL changes:
# NEXT_PUBLIC_GOOGLE_MAPS_URL=https://maps.app.goo.gl/your-link
# NEXT_PUBLIC_INSTAGRAM_HANDLE=yourcompany
# Or full URL:
# NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/yourcompany/

# Urban renewal — founder Q&A videos: upload in Django admin (Founder videos → video + poster image).
# Public list: GET /api/founder-videos/ (no extra Next env vars).
