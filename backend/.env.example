# Django / DRF — copy to `backend/.env` for local `manage.py` outside Docker.
# With `docker compose`, the same variables are injected from compose defaults (override via a root `.env` file next to `docker-compose.yml`).

DEBUG=True
SECRET_KEY=change-me-generate-a-long-random-string-for-production

ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Production (DEBUG=False): settings enable secure cookies, HSTS, etc. Optional overrides:
# SECURE_SSL_REDIRECT=false   # if TLS redirect is done only at nginx/Caddy (default is true when DEBUG=False)
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_PRELOAD=true
# CSRF_TRUSTED_ORIGINS=https://your-frontend.example.com

# Match PostgreSQL service in docker-compose.yml (or override POSTGRES_* in root `.env`).
# IMPORTANT: In the devcontainer, use DATABASE_HOST=db (the Compose service name). `localhost`
# will fail — Postgres is not running inside the devcontainer VM on port 5432.
# Copy this file to `backend/.env` only if you need overrides (defaults in settings + compose are enough for Docker dev).
DATABASE_NAME=construction_db
DATABASE_USER=construction
DATABASE_PASSWORD=construction_dev
DATABASE_HOST=db
DATABASE_PORT=5432

# CORS: browser origins allowed to call the API (comma-separated).
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Cloudinary: site hero, project gallery images, announcements (image/video), founder videos.
# Migrating from local MEDIA files → CloudinaryField clears old DB paths; re-upload those assets in admin after migrate.
# Founder Q&A videos (urban renewal page): Django admin → Founder videos.
# Uploads go to Cloudinary — create a free account and set either CLOUDINARY_URL or:
# https://cloudinary.com/documentation/django_integration
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Homepage hero video: Django admin → Site settings → hero video (stored under MEDIA_ROOT/site/hero/).

# Media uploads (construction photos, announcements). Use a persistent volume in production.
# Local dev: the OS user running runserver must be able to write MEDIA_ROOT (e.g. chown -R $USER backend/media).
MEDIA_ROOT=/app/media
MEDIA_URL=/media/

# DRF: all /api/* routes require a staff user (same as Django admin): Session cookie after
# /admin/ login, or Authorization: Token <key> for a staff user’s token.
# Create a token: `python manage.py shell` →
#   from django.contrib.auth import get_user_model; from rest_framework.authtoken.models import Token
#   u = get_user_model().objects.get(username="YOUR_STAFF_USER"); print(Token.objects.get_or_create(user=u)[0].key)
# Put that key in the Next.js server env as INTERNAL_API_AUTH_TOKEN (see frontend/.env.example).
# POST /api/auth/token/ with JSON {"username":"...","password":"..."} still returns a token (any user);
# only staff tokens work on /api/*.
#
# Optional: future Telegram webhook verification, etc.
# TELEGRAM_WEBHOOK_SECRET=
