{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Frontend",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend",
        "env": { "NODE_ENV": "development" }
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "next",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Ready in|started server"
        }
      },
      "presentation": { "reveal": "always", "panel": "shared", "group": "dev" }
    },
    {
      "label": "Backend",
      "type": "shell",
      "command": "python3 manage.py runserver 0.0.0.0:8000",
      "options": {
        "cwd": "${workspaceFolder}/backend",
        "env": { "PYTHONUNBUFFERED": "1" },
        "envFile": "${workspaceFolder}/backend/.env"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "django",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Starting development server|Quit the server"
        }
      },
      "presentation": { "reveal": "always", "panel": "shared", "group": "dev" }
    }
  ]
}
